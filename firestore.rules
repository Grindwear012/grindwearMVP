rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "mohalashelldon@gmail.com"
      );
    }

    // --- COLLECTION GROUP RULES ---

    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      // Allow initial registration for the master email
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.token.email == "mohalashelldon@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
  }
}
