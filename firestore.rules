rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check for existence of a document in roles_admin with ID = user UID
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION GROUP RULES ---

    /**
     * @description Allow collection group queries for orders.
     * This is critical for the Admin Dashboard to list orders from all customers.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data
    match /customers/{customerId} {
      // Users can manage their own profile; admins can see everything.
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      // All subcollections (addresses, carts, interactions, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      // Admins can read the list of admins; no one can write via the client SDK (managed via Console/Admin SDK).
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
