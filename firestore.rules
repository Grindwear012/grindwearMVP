rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit check for the master admin email or existence in the admin roles collection
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mohalashelldon@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- COLLECTION GROUP RULES ---
    // This is critical for the Admin Dashboard to list orders across all customers
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data
    match /customers/{customerId} {
      // Users can manage their own profile and data
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      // Allow any signed-in user to check if an admin role exists
      allow read: if isSignedIn();
      // Only the system or existing admins can grant admin roles
      allow write: if isSignedIn() && (
        request.auth.token.email == "mohalashelldon@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    // Support for root-level orders if used
    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }
  }
}