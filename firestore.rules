rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     *
     * Core Philosophy: 
     * This ruleset enforces a strict Path-Based Ownership model combined with Database Access Control (DBAC) 
     * for administrative privileges. User data is isolated within specific customer paths, while 
     * global roles are managed via a dedicated admin collection.
     *
     * Data Structure:
     * - /customers/{customerId}: The root of user-specific data (Profiles, Addresses, Carts, Orders).
     * - /products/{productId}: A top-level public catalog.
     * - /roles_admin/{adminId}: Metadata collection used to identify system administrators.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Ownership is verified directly from the document path parameters 
     *    (e.g., {customerId}) to avoid expensive and slow cross-document lookups.
     * 2. Administrative Access: Admin privileges are granted by checking for the existence of a 
     *    document in the /roles_admin collection. Admins have read access to all orders for management.
     * 3. Prototyping Flexibility: Rules strictly enforce WHO can access data but do NOT enforce 
     *    strict field types or schemas (except for relational IDs like customerId), allowing for 
     *    rapid UI and backend iteration.
     * 4. Denormalization for Performance: Relational links (like customerId) are enforced on 
     *    creation to ensure path-to-data consistency.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Used for updates/deletes to ensure the resource exists and belongs to the user
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the admin roles collection. Entry existence defines admin status.
     * @path /roles_admin/{adminId}
     * @allow (get) If the user is the admin themselves or another admin.
     * @deny (write) Direct client-side modification of roles is prohibited.
     * @principle System-wide role assignment via DBAC.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    /**
     * @description User profile management. Users can only manage their own profile.
     * @path /customers/{customerId}
     * @allow (create) If the document ID matches the auth UID.
     * @deny (update) If the user attempts to change their internal 'id' field.
     * @principle Self-creation and strict ownership for root user documents.
     */
    match /customers/{customerId} {
      allow get, list: if isOwner(customerId) || isAdmin();
      allow create: if isOwner(customerId) && request.resource.data.id == customerId;
      allow update: if isExistingOwner(customerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Customer-owned subcollections (Addresses, PaymentMethods, Carts, Interactions).
     * @path /customers/{customerId}/[subcollection]/{id}
     * @allow (all) Access granted only to the specific customer identified in the path.
     * @deny (all) Access to other users' data or unauthenticated requests.
     * @principle Path-based ownership provides atomic and performant authorization.
     */
    match /customers/{customerId}/addresses/{addressId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
      allow update: if isExistingOwner(customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isExistingOwner(customerId);
    }

    match /customers/{customerId}/paymentMethods/{paymentMethodId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
      allow update: if isExistingOwner(customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isExistingOwner(customerId);
    }

    match /customers/{customerId}/carts/{cartId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
      allow update: if isExistingOwner(customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isExistingOwner(customerId);
    }

    match /customers/{customerId}/carts/{cartId}/items/{cartItemId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    match /customers/{customerId}/productInteractions/{interactionId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
      allow update, delete: if isExistingOwner(customerId);
    }

    /**
     * @description Order management. Customers can create/read their orders; admins can read/manage all orders.
     * @path /customers/{customerId}/orders/{orderId}
     * @allow (get, list) If user is the customer or an administrator.
     * @deny (create) If the internal customerId does not match the authenticated path.
     * @principle Owner-writes with administrative oversight.
     */
    match /customers/{customerId}/orders/{orderId} {
      allow get, list: if isOwnerOrAdmin(customerId);
      allow create: if isOwner(customerId) && request.resource.data.customerId == customerId;
      allow update, delete: if isOwnerOrAdmin(customerId) && resource != null;
    }

    match /customers/{customerId}/orders/{orderId}/items/{orderItemId} {
      allow get, list: if isOwnerOrAdmin(customerId);
      allow create: if isOwner(customerId);
      allow update, delete: if isOwnerOrAdmin(customerId) && resource != null;
    }

    /**
     * @description Product catalog rules.
     * @path /products/{productId}
     * @allow (get, list) Publicly readable for all users.
     * @deny (write) Only administrative users can modify product data.
     * @principle Public consumption with secure, centralized management.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}