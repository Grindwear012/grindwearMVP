rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - SECURE FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Secure isAdmin check: relies exclusively on the roles_admin collection
    // This function checks if a document exists in roles_admin with the user's UID as ID.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION GROUP RULES ---
    
    // Allow admins to list all orders across all customer collections for the dashboard
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products, admin-only write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data (Ownership check)
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      // Users can read their own admin document to check authorization status
      allow get: if isSignedIn() && request.auth.uid == adminId;
      // Only existing admins can list or manage other admin roles
      allow list, write: if isAdmin();
    }
  }
}