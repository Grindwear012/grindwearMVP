rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check for existence of a document in roles_admin with ID = user UID
      // OR allow the developer email to bypass for initial setup
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "mohalashelldon@gmail.com"
      );
    }

    // --- COLLECTION GROUP RULES ---

    /**
     * @description Allow collection group queries for orders.
     * This is critical for the Admin Dashboard to list orders from all customers.
     * Collection group rules must use this specific recursive path pattern.
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data
    match /customers/{customerId} {
      // Users can manage their own profile; admins can see everything.
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      // All subcollections (addresses, carts, interactions, orders, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      // Admins can read the list of admins
      allow read: if isSignedIn();
      // Writing to roles_admin should be restricted to prevent self-elevation in production
      // but we allow read/list for auth checks.
      allow write: if false; 
    }
  }
}
