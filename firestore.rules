rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * THRIFT PLUG - FIRESTORE SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Prototyping: Allow all signed-in users to act as admins.
      // This resolves permission issues during development.
      return isSignedIn();
    }

    // --- COLLECTION GROUP RULES ---

    /**
     * @description Allow collection group queries for orders.
     * This is critical for the Admin Dashboard to list orders from all customers.
     * Note: A collection group index on 'orders' (field: 'createdAt') is required for sorting.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Publicly readable products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer-specific data
    match /customers/{customerId} {
      // Users can manage their own profile; admins can see everything.
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());

      // All subcollections (addresses, carts, interactions, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    // Admin role definitions
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Admin SDK or Console
    }
  }
}
